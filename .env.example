# PayPal Configuration
# For LIVE: Use your live PayPal client ID from https://developer.paypal.com/dashboard/apps/live
# For SANDBOX (testing): Use your sandbox PayPal client ID
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here
# PayPal automatically uses LIVE or SANDBOX based on the client ID provided above

# Polygon/Blockchain Configuration
POLYGON_RPC=https://polygon-rpc.com/
TREASURY_PRIVATE_KEY=your_treasury_wallet_private_key_here

# Database Configuration
DATABASE_URL=your_database_url_here

# Application
NODE_ENV=development
PORT=5000
